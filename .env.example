# 数据库配置
DATABASE_URL="postgresql://username:password@localhost:5432/neuro_source_localization?schema=public"

# Redis配置
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""
REDIS_DB=0

# RabbitMQ配置
RABBITMQ_URL="amqp://guest:guest@localhost:5672"

# MinIO对象存储配置
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET="neuro-data"
MINIO_USE_SSL=false

# JWT配置
JWT_ACCESS_SECRET="your-access-token-secret-key-change-in-production"
JWT_REFRESH_SECRET="your-refresh-token-secret-key-change-in-production"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# 服务器配置
SERVER_PORT=3001
SERVER_HOST="0.0.0.0"
CLIENT_URL="http://localhost:5173"

# 计算引擎配置
COMPUTE_ENGINE_URL="http://localhost:8001"
COMPUTE_TIMEOUT=3600000

# 预警阈值配置
RESIDUAL_THRESHOLD=10
SOURCE_OFFSET_THRESHOLD=5
PATIENT_DEVIATION_THRESHOLD=8
CONSECUTIVE_DEVIATION_COUNT=3
AUTO_SUSPEND_ENABLED=true

# 导航系统配置
NAVIGATION_SYSTEM_URL="http://navigation-system.local/api"

# 日志配置
LOG_LEVEL="info"
LOG_FILE="./logs/app.log"

# 环境配置
NODE_ENV="development"
